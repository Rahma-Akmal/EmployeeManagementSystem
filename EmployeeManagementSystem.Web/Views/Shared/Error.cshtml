@model ErrorViewModel

@{
    ViewData["Title"] = "Error";
}
<style>
    .error-box {
        background: #f9f9f9;
        border: 1px solid #e5e5e5;
        padding: 12px 15px;
        border-radius: 8px;
        color: #333;
        /* 🔥 أهم سطرين */
        direction: ltr;
        text-align: left !important;
    }
</style>

<div class="page">

    <main class="page">

        <!-- ===== Top Navbar ===== -->
        <nav class="addition_nav">

            <div class="right-group">

                <h2 class="page-title text-danger">
                    ❌ Something went wrong
                </h2>

            </div>

            <div class="nav-left-buttons">
                <a href="/" class="btn-save">
                    Back Home
                </a>
            </div>

        </nav>

        <!-- ===== Page Grid ===== -->
        <div class="page-grid">

            <!-- Left Side -->
            <div>

                <!-- Error Message -->
                <div class="edit-card"
                     style="background:#fff; border:1px solid #eee;margin-top:50px;padding:15px;">

                    <div class="input-title">
                        Error Message
                    </div>

                    <div class="error-box">
                        @Model.Message
                    </div>

                </div>

            </div>

            <!-- Right Side -->
            <div>

                @if (!string.IsNullOrEmpty(Model.StackTrace))
                {
                    <div class="edit-card"
                         style="background:#fff; border:1px solid #eee;padding:15px;margin-top:50px;">

                        <div class="input-title text-danger">
                            Stack Trace
                        </div>

                        <pre class="stack-box">
@Model.StackTrace
                        </pre>

                    </div>
                }

            </div>

        </div>

    </main>

</div>